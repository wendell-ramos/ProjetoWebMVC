@model List<ProjetoPericiaContabil.Models.HistoricoAtividade>
@using System.Collections.Generic

@{
    ViewBag.Title = "Hist&oacute;rico do Sistema";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var atividadesLookup = ViewBag.AtividadesLookup as Dictionary<int, string> ?? new Dictionary<int, string>();
}

<div class="page-header">
    <div>
        <h1 class="page-title">Hist&oacute;rico do Sistema</h1>
        <p class="page-subtitle">Acompanhe as principais a&ccedil;&otilde;es registradas no fluxo de atividades, usu&aacute;rios e arquivos.</p>
    </div>
    <div class="page-actions">
        <a href="@Url.Action("Index", "Usuario")" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Voltar ao painel
        </a>
    </div>
</div>

@if (TempData["Erro"] != null)
{
    <div class="alert alert-danger">@TempData["Erro"]</div>
}

<section class="filters mb-4">
    @using (Html.BeginForm("Historico", "Admin", FormMethod.Get))
    {
        <div class="filter-grid">
            <div>
                <label class="form-label">Usu&aacute;rio</label>
                <input class="form-control" type="text" name="nomeUsuario" value="@ViewBag.NomeUsuario" placeholder="Nome do usu&aacute;rio" />
            </div>

            <div>
                <label class="form-label">A&ccedil;&atilde;o</label>
                <input class="form-control" type="text" name="acao" value="@ViewBag.Acao" placeholder="Ex.: finalizou" />
            </div>

            <div>
                <label class="form-label">Tipo do usu&aacute;rio</label>
                <select class="form-select" name="tipoUsuario">
                    <option value="">Todos</option>
                    <option value="Admin" @(ViewBag.TipoUsuario == "Admin" ? "selected" : "")>Admin</option>
                    <option value="Cliente" @(ViewBag.TipoUsuario == "Cliente" ? "selected" : "")>Cliente</option>
                    <option value="Funcionario" @(ViewBag.TipoUsuario == "Funcionario" ? "selected" : "")>Funcion&aacute;rio</option>
                </select>
            </div>

            <div>
                <label class="form-label">Data inicial</label>
                <input class="form-control" type="date" name="dataInicial" value="@ViewBag.DataInicial" />
            </div>

            <div>
                <label class="form-label">Data final</label>
                <input class="form-control" type="date" name="dataFinal" value="@ViewBag.DataFinal" />
            </div>

            <div class="actions">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-funnel"></i> Filtrar
                </button>
                <a href="@Url.Action("Historico", "Admin")" class="btn btn-secondary">Limpar</a>
            </div>
        </div>
    }
</section>

<section class="card table-card">
    @if (Model != null && Model.Count > 0)
    {
        <div class="table-responsive">
            <table class="table app-table">
                <thead>
                    <tr>
                        <th>Data/Hora</th>
                        <th>Usu&aacute;rio</th>
                        <th>Tipo</th>
                        <th>Atividade</th>
                        <th>A&ccedil;&atilde;o</th>
                        <th>Descri&ccedil;&atilde;o</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.DataHora.ToString("dd/MM/yyyy HH:mm")</td>
                            <td><strong>@item.NomeUsuario</strong></td>
                            <td><span class="status-badge status-default">@item.TipoUsuario</span></td>
                            <td>
                                @if (item.AtividadeId.HasValue)
                                {
                                    var titulo = atividadesLookup.ContainsKey(item.AtividadeId.Value) ? atividadesLookup[item.AtividadeId.Value] : "Atividade";
                                    <a class="link" href="@Url.Action("Details", "Atividade", new { id = item.AtividadeId.Value })">
                                        #@item.AtividadeId - @titulo
                                    </a>
                                }
                                else
                                {
                                    <span class="empty">Sem atividade</span>
                                }
                            </td>
                            <td>@item.Acao</td>
                            <td>@item.Descricao</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="p-4 empty">Nenhum registro encontrado.</div>
    }
</section>
