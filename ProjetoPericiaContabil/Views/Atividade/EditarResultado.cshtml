@model ProjetoPericiaContabil.Models.Atividade

@{
    ViewBag.Title = "Editar Resultado";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Editar Resultado</h1>
        <p class="page-subtitle">Atualize o texto do resultado antes da confirma&ccedil;&atilde;o de leitura pelo cliente.</p>
    </div>
    <div class="page-actions">
        <a class="btn btn-secondary" href="@Url.Action("MinhasFuncionario", "Atividade")">
            <i class="bi bi-arrow-left"></i> Voltar
        </a>
    </div>
</div>

<section class="form-card">
    <div class="info-box p-3 mb-3">
        <span class="text-muted-app d-block">Atividade</span>
        <strong>@Model.Titulo</strong>
    </div>

    <div class="mb-3">
        <label class="form-label">Solicita&ccedil;&atilde;o do cliente</label>
        <div class="descricao-box p-3">@Model.Descricao</div>
    </div>

    <form method="post" class="d-grid gap-3">
        <input type="hidden" name="Id" value="@Model.Id" />

        <div>
            <label class="form-label">Resultado</label>
            <textarea class="form-control" name="Resultado" required>@Model.Resultado</textarea>
        </div>

        <div class="actions justify-content-between">
            <a class="btn btn-secondary" href="@Url.Action("MinhasFuncionario", "Atividade")">Cancelar</a>
            <button type="submit" class="btn btn-primary">
                <i class="bi bi-save"></i> Salvar Altera&ccedil;&otilde;es
            </button>
        </div>
    </form>
</section>
