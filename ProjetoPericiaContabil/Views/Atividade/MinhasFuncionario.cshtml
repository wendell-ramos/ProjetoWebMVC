@model List<ProjetoPericiaContabil.Models.Atividade>

@{
    ViewBag.Title = "Minhas Atividades";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Minhas Atividades</h1>
        <p class="page-subtitle">Atividades atribu&iacute;das ao funcion&aacute;rio, com acesso a arquivos, finaliza&ccedil;&atilde;o e edi&ccedil;&atilde;o de resultados.</p>
    </div>
    <div class="page-actions">
        <a class="btn btn-secondary" href="@Url.Action("Disponiveis", "Atividade")">
            <i class="bi bi-inbox"></i> Dispon&iacute;veis
        </a>
        <a class="btn btn-secondary" href="@Url.Action("Arquivadas", "Atividade")">
            <i class="bi bi-archive"></i> Arquivadas
        </a>
    </div>
</div>

<section class="card table-card">
    <div class="table-responsive">
        <table class="table app-table">
            <thead>
                <tr>
                    <th>T&iacute;tulo</th>
                    <th>Descri&ccedil;&atilde;o</th>
                    <th>Arquivos</th>
                    <th>Status</th>
                    <th>A&ccedil;&atilde;o</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    var statusClass = item.Status == "EmElaboracao" ? "status-elaboracao" : item.Status == "Concluida" ? "status-concluida" : "status-default";
                    var statusText = item.Status == "EmElaboracao" ? "Em elabora&ccedil;&atilde;o" : item.Status == "Concluida" ? "Conclu&iacute;da" : item.Status;

                    <tr>
                        <td><strong>@item.Titulo</strong></td>
                        <td><div class="descricao">@item.Descricao</div></td>
                        <td>
                            @if (!string.IsNullOrEmpty(item.ArquivoClienteCaminho))
                            {
                                <a class="arquivo-link d-block" href="@Url.Action("BaixarArquivoCliente", "Atividade", new { id = item.Id })">
                                    <i class="bi bi-paperclip"></i> Arquivo do cliente
                                </a>
                            }
                            @if (!string.IsNullOrEmpty(item.ArquivoResultadoCaminho))
                            {
                                <a class="arquivo-link d-block" href="@Url.Action("BaixarArquivoResultado", "Atividade", new { id = item.Id })">
                                    <i class="bi bi-file-earmark-check"></i> Arquivo do resultado
                                </a>
                            }
                            else if (string.IsNullOrEmpty(item.ArquivoClienteCaminho))
                            {
                                <span class="arquivo-vazio">Sem arquivos</span>
                            }
                        </td>
                        <td><span class="status-badge @statusClass">@Html.Raw(statusText)</span></td>
                        <td>
                            <div class="table-actions">
                                <a class="btn btn-secondary btn-sm" href="@Url.Action("Details", "Atividade", new { id = item.Id })">
                                    <i class="bi bi-eye"></i> Detalhes
                                </a>
                                @if (item.Status == "EmElaboracao")
                                {
                                    <a class="btn btn-primary btn-sm" href="@Url.Action("Finalizar", "Atividade", new { id = item.Id })">
                                        <i class="bi bi-check2-circle"></i> Finalizar
                                    </a>
                                }
                                else if (item.Status == "Concluida" && item.ClienteVisualizou == false)
                                {
                                    <a class="btn btn-primary btn-sm" href="@Url.Action("EditarResultado", "Atividade", new { id = item.Id })">
                                        <i class="bi bi-pencil-square"></i> Editar Resultado
                                    </a>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</section>
