@model ProjetoPericiaContabil.Models.Atividade

@{
    ViewBag.Title = "Nova Atividade";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Nova Atividade</h1>
        <p class="page-subtitle">Registre uma solicita&ccedil;&atilde;o pericial com descri&ccedil;&atilde;o, setor de c&aacute;lculo e arquivo inicial, se necess&aacute;rio.</p>
    </div>
    <div class="page-actions">
        <a class="btn btn-secondary" href="@Url.Action("Minhas", "Atividade")">
            <i class="bi bi-arrow-left"></i> Voltar
        </a>
    </div>
</div>

<section class="form-card">
    @if (ViewBag.Erro != null)
    {
        <div class="alert alert-danger">@ViewBag.Erro</div>
    }

    @Html.ValidationSummary(false, "", new { @class = "validation-summary-errors" })

    <form method="post" enctype="multipart/form-data" class="d-grid gap-3">
        <div>
            <label class="form-label">T&iacute;tulo</label>
            <input class="form-control" type="text" name="Titulo" value="@(Model != null ? Model.Titulo : "")" placeholder="Digite o t&iacute;tulo da atividade" required />
        </div>

        <div>
            <label class="form-label">Descri&ccedil;&atilde;o</label>
            <textarea class="form-control" name="Descricao" placeholder="Descreva o que precisa ser analisado..." required>@(Model != null ? Model.Descricao : "")</textarea>
        </div>

        <div>
            <label class="form-label">Tipo de C&aacute;lculo</label>
            <select class="form-select" name="TipoCalculo" required>
                <option value="Cível" @(Model != null && Model.TipoCalculo == "Cível" ? "selected" : "")>C&iacute;vel</option>
                <option value="Trabalhista" @(Model != null && Model.TipoCalculo == "Trabalhista" ? "selected" : "")>Trabalhista</option>
                <option value="Tributário" @(Model != null && Model.TipoCalculo == "Tributário" ? "selected" : "")>Tribut&aacute;rio</option>
                <option value="Previdenciário" @(Model != null && Model.TipoCalculo == "Previdenciário" ? "selected" : "")>Previdenci&aacute;rio</option>
            </select>
        </div>

        <div>
            <label class="form-label">Arquivo do Cliente</label>
            <input class="form-control" type="file" name="arquivoCliente" accept=".pdf,.doc,.docx,.xls,.xlsx,.png,.jpg,.jpeg" />
            <div class="form-text text-muted-app">PDF, DOC, DOCX, XLS, XLSX, PNG ou JPG.</div>
        </div>

        <div class="actions justify-content-between">
            <a class="btn btn-secondary" href="@Url.Action("Minhas", "Atividade")">Cancelar</a>
            <button type="submit" class="btn btn-primary">
                <i class="bi bi-check2-circle"></i> Salvar Atividade
            </button>
        </div>
    </form>
</section>
