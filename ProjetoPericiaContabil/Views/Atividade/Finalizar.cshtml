@model ProjetoPericiaContabil.Models.Atividade

@{
    Layout = null;
}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">

<style>
    body {
        margin: 0;
        font-family: 'DM Sans', sans-serif;
        height: 100vh;
        background: linear-gradient(135deg, #1a2332, #243044, #0f172a);
        color: #fff;
    }
    .btn-logout {
        padding: 8px 14px;
        background: rgba(255,255,255,0.1);
        color: #fff;
        border-radius: 6px;
        text-decoration: none;
        font-size: 13px;
        transition: 0.2s;
    }

        .btn-logout:hover {
            background: rgba(255,255,255,0.2);
        }

    .bg-circle {
        position: absolute;
        border-radius: 50%;
        filter: blur(120px);
        opacity: 0.3;
    }

    .circle1 {
        width: 300px;
        height: 300px;
        background: #c9a84c;
        top: 10%;
        left: 10%;
    }

    .circle2 {
        width: 400px;
        height: 400px;
        background: #3b82f6;
        bottom: 10%;
        right: 10%;
    }

    .container {
        height: 100vh;
        display: flex;
        justify-content: center;
        align-items: center;
        position: relative;
        z-index: 1;
        padding: 20px;
    }

    .card {
        width: 100%;
        max-width: 500px;
        background: rgba(255,255,255,0.05);
        backdrop-filter: blur(20px);
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 10px;
        padding: 30px;
        box-shadow: 0 10px 40px rgba(0,0,0,0.4);
        animation: fadeUp 0.4s ease;
    }

    @@keyframes fadeUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .card h2 {
        font-family: 'Playfair Display', serif;
        margin-bottom: 20px;
        font-size: 26px;
    }

    .info {
        font-size: 13px;
        color: #ccc;
        margin-bottom: 15px;
        line-height: 1.6;
    }

    .descricao-box {
        background: rgba(255,255,255,0.08);
        border: 1px solid rgba(255,255,255,0.12);
        border-radius: 8px;
        padding: 12px;
        margin-bottom: 20px;
        color: #eee;
        font-size: 14px;
        line-height: 1.6;
        white-space: pre-line;
    }

    textarea {
        width: 100%;
        min-height: 120px;
        border-radius: 6px;
        border: 1px solid rgba(255,255,255,0.2);
        background: rgba(255,255,255,0.1);
        color: #fff;
        padding: 10px;
        resize: none;
        outline: none;
        transition: 0.2s;
    }

        textarea:focus {
            border-color: #c9a84c;
            background: rgba(255,255,255,0.15);
        }

    label {
        display: block;
        font-size: 13px;
        color: #ccc;
        margin: 15px 0 6px;
    }

    input[type="file"] {
        width: 100%;
        padding: 10px 12px;
        border-radius: 6px;
        border: 1px solid rgba(255,255,255,0.2);
        background: rgba(255,255,255,0.1);
        color: #fff;
        outline: none;
    }

    .actions {
        margin-top: 20px;
        display: flex;
        justify-content: space-between;
    }

    .btn {
        padding: 10px 16px;
        border-radius: 6px;
        text-decoration: none;
        font-size: 13px;
        font-weight: bold;
        transition: 0.2s;
    }

    .btn-back {
        background: rgba(255,255,255,0.1);
        color: #fff;
    }

        .btn-back:hover {
            background: rgba(255,255,255,0.2);
        }

    .btn-save {
        background: linear-gradient(135deg, #c9a84c, #e0c36c);
        color: #1a2332;
        border: none;
        cursor: pointer;
    }

        .btn-save:hover {
            box-shadow: 0 5px 20px rgba(201,168,76,0.4);
            transform: translateY(-1px);
        }

    .arquivo-link {
        display: inline-block;
        margin-top: 4px;
        color: #c9a84c;
        font-size: 13px;
        text-decoration: none;
    }

        .arquivo-link:hover {
            text-decoration: underline;
        }

    .erro-box {
        background: rgba(255, 80, 80, 0.15);
        border: 1px solid rgba(255, 80, 80, 0.4);
        color: #ffd6d6;
        padding: 10px;
        border-radius: 6px;
        font-size: 13px;
        margin-bottom: 15px;
        text-align: center;
    }
</style>

<!-- Fundo -->
<div class="bg-circle circle1"></div>
<div class="bg-circle circle2"></div>

<div class="container">
    <div style="position:absolute; top:20px; right:20px;">
        <a href="@Url.Action("Logout", "Usuario")" class="btn-logout">
            Sair
        </a>
    </div>
    <div class="card">

        <h2>Finalizar Atividade</h2>

        @if (ViewBag.Erro != null)
        {
            <div class="erro-box">@ViewBag.Erro</div>
        }

        <div class="info">
            <strong>Atividade:</strong> @Model.Titulo
        </div>

        <div class="info">
            <strong>Solicitação do cliente:</strong>
        </div>

        <div class="descricao-box">
            @Model.Descricao
        </div>

        @if (!string.IsNullOrEmpty(Model.ArquivoClienteCaminho))
        {
            <div class="info">
                <strong>Arquivo do cliente:</strong>
                <a class="arquivo-link" href="@Url.Action("DownloadArquivo", "Atividade", new { id = Model.Id, tipo = "cliente" })">
                    @Model.ArquivoClienteNome
                </a>
            </div>
        }

        <form method="post" enctype="multipart/form-data">
            <input type="hidden" name="Id" value="@Model.Id" />

            <textarea name="Resultado" placeholder="Descreva o resultado da atividade..." required></textarea>

            <label>Arquivo de Resultado</label>
            <input type="file" name="arquivoResultado" accept=".pdf,.doc,.docx,.xls,.xlsx" />

            <div class="actions">
                <a class="btn btn-back" href="@Url.Action("MinhasFuncionario", "Atividade")">
                    Voltar
                </a>

                <button type="submit" class="btn btn-save">
                    Finalizar
                </button>
            </div>
        </form>

    </div>

</div>
