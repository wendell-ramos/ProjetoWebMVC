@model ProjetoPericiaContabil.Models.Atividade

@{
    ViewBag.Title = "Finalizar Atividade";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Finalizar Atividade</h1>
        <p class="page-subtitle">Informe o resultado pericial e anexe o arquivo final quando houver documenta&ccedil;&atilde;o complementar.</p>
    </div>
    <div class="page-actions">
        <a class="btn btn-secondary" href="@Url.Action("MinhasFuncionario", "Atividade")">
            <i class="bi bi-arrow-left"></i> Voltar
        </a>
    </div>
</div>

<section class="form-card">
    @if (ViewBag.Erro != null)
    {
        <div class="alert alert-danger">@ViewBag.Erro</div>
    }

    <div class="info-box p-3 mb-3">
        <span class="text-muted-app d-block">Atividade</span>
        <strong>@Model.Titulo</strong>
    </div>

    <div class="mb-3">
        <label class="form-label">Solicita&ccedil;&atilde;o do cliente</label>
        <div class="descricao-box p-3">@Model.Descricao</div>
    </div>

    @if (!string.IsNullOrEmpty(Model.ArquivoClienteCaminho))
    {
        <div class="file-card">
            <span class="file-name">@Model.ArquivoClienteNome</span>
            <a class="btn btn-secondary btn-sm" href="@Url.Action("BaixarArquivoCliente", "Atividade", new { id = Model.Id })">
                <i class="bi bi-download"></i> Baixar arquivo do cliente
            </a>
        </div>
    }

    <form method="post" enctype="multipart/form-data" class="d-grid gap-3">
        <input type="hidden" name="Id" value="@Model.Id" />

        <div>
            <label class="form-label">Resultado</label>
            <textarea class="form-control" name="Resultado" placeholder="Descreva o resultado da atividade..." required></textarea>
        </div>

        <div>
            <label class="form-label">Arquivo de Resultado</label>
            <input class="form-control" type="file" name="arquivoResultado" accept=".pdf,.doc,.docx,.xls,.xlsx" />
        </div>

        <div class="actions justify-content-between">
            <a class="btn btn-secondary" href="@Url.Action("MinhasFuncionario", "Atividade")">Cancelar</a>
            <button type="submit" class="btn btn-primary">
                <i class="bi bi-check2-circle"></i> Finalizar
            </button>
        </div>
    </form>
</section>
