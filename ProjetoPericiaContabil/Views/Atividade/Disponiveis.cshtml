@model List<ProjetoPericiaContabil.Models.Atividade>

@{
    ViewBag.Title = "Atividades Dispon&iacute;veis";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Atividades Dispon&iacute;veis</h1>
        <p class="page-subtitle">Solicita&ccedil;&otilde;es em an&aacute;lise compat&iacute;veis com o setor do funcion&aacute;rio.</p>
    </div>
    <div class="page-actions">
        <a class="btn btn-secondary" href="@Url.Action("MinhasFuncionario", "Atividade")">
            <i class="bi bi-briefcase"></i> Minhas Atividades
        </a>
    </div>
</div>

@if (TempData["Erro"] != null)
{
    <div class="alert alert-danger">@TempData["Erro"]</div>
}

<section class="card table-card">
    <div class="table-responsive">
        <table class="table app-table">
            <thead>
                <tr>
                    <th>T&iacute;tulo</th>
                    <th>Descri&ccedil;&atilde;o</th>
                    <th>Tipo</th>
                    <th>Arquivo</th>
                    <th>A&ccedil;&atilde;o</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td><strong>@item.Titulo</strong></td>
                        <td><div class="descricao">@item.Descricao</div></td>
                        <td><span class="status-badge status-default">@item.TipoCalculo</span></td>
                        <td>
                            @if (!string.IsNullOrEmpty(item.ArquivoClienteCaminho))
                            {
                                <a class="arquivo-link" href="@Url.Action("BaixarArquivoCliente", "Atividade", new { id = item.Id })">
                                    <i class="bi bi-download"></i> Arquivo do cliente
                                </a>
                            }
                            else
                            {
                                <span class="arquivo-vazio">Sem arquivo</span>
                            }
                        </td>
                        <td>
                            <div class="table-actions">
                                <a class="btn btn-secondary btn-sm" href="@Url.Action("Details", "Atividade", new { id = item.Id })">
                                    <i class="bi bi-eye"></i> Detalhes
                                </a>
                                <a class="btn btn-primary btn-sm" href="@Url.Action("Pegar", "Atividade", new { id = item.Id })">
                                    <i class="bi bi-person-check"></i> Pegar
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</section>
