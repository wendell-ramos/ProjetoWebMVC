@model ProjetoPericiaContabil.Models.ViewModels.AtividadeDetailsViewModel

@{
    Layout = null;
    var tipoUsuario = Session["Tipo"] != null ? Session["Tipo"].ToString() : "";
    var voltarController = "Home";
    var voltarAction = "Index";

    if (tipoUsuario == "Admin")
    {
        voltarController = "Usuario";
        voltarAction = "Index";
    }
    else if (tipoUsuario == "Cliente")
    {
        voltarController = "Atividade";
        voltarAction = "Minhas";
    }
    else if (tipoUsuario == "Funcionario")
    {
        voltarController = "Atividade";
        voltarAction = Model.FuncionarioNome == null ? "Disponiveis" : "MinhasFuncionario";
    }
}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">

<style>
    body {
        margin: 0;
        font-family: 'DM Sans', sans-serif;
        min-height: 100vh;
        background: linear-gradient(135deg, #1a2332, #243044, #0f172a);
        color: #fff;
    }

    .bg-circle {
        position: fixed;
        border-radius: 50%;
        filter: blur(120px);
        opacity: 0.3;
        pointer-events: none;
    }

    .circle1 {
        width: 300px;
        height: 300px;
        background: #c9a84c;
        top: 10%;
        left: 10%;
    }

    .circle2 {
        width: 400px;
        height: 400px;
        background: #3b82f6;
        bottom: 10%;
        right: 10%;
    }

    .container {
        position: relative;
        z-index: 1;
        width: min(1100px, calc(100% - 40px));
        margin: 0 auto;
        padding: 40px 0;
    }

    .topbar {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 20px;
        margin-bottom: 22px;
        flex-wrap: wrap;
    }

    .topbar h1 {
        font-family: 'Playfair Display', serif;
        font-size: 32px;
        margin: 0 0 8px;
    }

    .subtitle {
        color: #ccc;
        font-size: 14px;
    }

    .badge {
        display: inline-block;
        padding: 6px 10px;
        border-radius: 999px;
        background: rgba(255,255,255,0.1);
        color: #c9a84c;
        font-size: 12px;
        font-weight: bold;
        white-space: nowrap;
    }

    .grid {
        display: grid;
        grid-template-columns: 1.1fr 0.9fr;
        gap: 18px;
    }

    .card {
        background: rgba(255,255,255,0.05);
        backdrop-filter: blur(20px);
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 8px;
        padding: 22px;
        box-shadow: 0 10px 40px rgba(0,0,0,0.35);
    }

    .card h2 {
        margin: 0 0 16px;
        font-size: 17px;
        color: #fff;
    }

    .meta-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 12px;
    }

    .meta {
        background: rgba(255,255,255,0.06);
        border-radius: 6px;
        padding: 12px;
    }

    .meta span {
        display: block;
        color: #c9a84c;
        font-size: 12px;
        margin-bottom: 5px;
    }

    .meta strong {
        display: block;
        color: #fff;
        font-size: 14px;
        overflow-wrap: anywhere;
    }

    .text-block {
        color: #ddd;
        font-size: 14px;
        line-height: 1.65;
        white-space: pre-line;
        overflow-wrap: anywhere;
    }

    .file-card {
        display: grid;
        gap: 10px;
        background: rgba(255,255,255,0.06);
        border-radius: 8px;
        padding: 14px;
        margin-bottom: 12px;
    }

    .file-name {
        color: #ddd;
        font-size: 13px;
        overflow-wrap: anywhere;
    }

    .empty {
        color: #888;
        font-size: 13px;
        font-style: italic;
    }

    .actions {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        margin-top: 18px;
    }

    .btn {
        display: inline-block;
        padding: 10px 14px;
        border-radius: 6px;
        text-decoration: none;
        font-size: 13px;
        font-weight: bold;
        border: none;
        cursor: pointer;
        transition: 0.2s;
        white-space: nowrap;
    }

    .btn-primary {
        background: linear-gradient(135deg, #c9a84c, #e0c36c);
        color: #1a2332;
    }

        .btn-primary:hover {
            box-shadow: 0 5px 18px rgba(201,168,76,0.38);
            transform: translateY(-1px);
        }

    .btn-secondary {
        background: rgba(255,255,255,0.1);
        color: #fff;
    }

        .btn-secondary:hover {
            background: rgba(255,255,255,0.18);
        }

    .history-list {
        display: grid;
        gap: 10px;
    }

    .history-item {
        display: grid;
        grid-template-columns: 150px 1fr;
        gap: 12px;
        padding: 12px;
        border-radius: 6px;
        background: rgba(255,255,255,0.06);
    }

    .history-date {
        color: #c9a84c;
        font-size: 12px;
        white-space: nowrap;
    }

    .history-content strong {
        display: block;
        font-size: 13px;
        color: #fff;
        margin-bottom: 4px;
    }

    .history-content span {
        display: block;
        color: #aaa;
        font-size: 12px;
        margin-bottom: 4px;
    }

    .history-content p {
        margin: 0;
        color: #ddd;
        font-size: 13px;
        line-height: 1.5;
    }

    @@media (max-width: 860px) {
        .grid,
        .meta-grid,
        .history-item {
            grid-template-columns: 1fr;
        }

        .container {
            width: calc(100% - 28px);
            padding: 28px 0;
        }
    }
</style>

<div class="bg-circle circle1"></div>
<div class="bg-circle circle2"></div>

<div class="container">
    <div class="topbar">
        <div>
            <h1>@Model.Titulo</h1>
            <div class="subtitle">Detalhes completos da atividade #@Model.Id</div>
        </div>
        <span class="badge">@Model.Status</span>
    </div>

    <div class="grid">
        <div>
            <div class="card">
                <h2>Resumo</h2>
                <div class="meta-grid">
                    <div class="meta">
                        <span>Tipo de c&aacute;lculo</span>
                        <strong>@Model.TipoCalculo</strong>
                    </div>
                    <div class="meta">
                        <span>Cliente</span>
                        <strong>@Model.ClienteNome</strong>
                    </div>
                    <div class="meta">
                        <span>Funcion&aacute;rio respons&aacute;vel</span>
                        <strong>
                            @if (!string.IsNullOrEmpty(Model.FuncionarioNome))
                            {
                                @Model.FuncionarioNome
                            }
                            else
                            {
                                <text>Ainda n&atilde;o atribu&iacute;do</text>
                            }
                        </strong>
                    </div>
                    <div class="meta">
                        <span>Cliente visualizou</span>
                        <strong>
                            @if (Model.ClienteVisualizou)
                            {
                                <text>Sim</text>
                            }
                            else
                            {
                                <text>N&atilde;o</text>
                            }
                        </strong>
                    </div>
                </div>
            </div>

            <div class="card" style="margin-top:18px;">
                <h2>Descri&ccedil;&atilde;o</h2>
                <div class="text-block">@Model.Descricao</div>
            </div>

            <div class="card" style="margin-top:18px;">
                <h2>Resultado</h2>
                @if (!string.IsNullOrWhiteSpace(Model.Resultado))
                {
                    <div class="text-block">@Model.Resultado</div>
                }
                else
                {
                    <span class="empty">Resultado ainda n&atilde;o informado.</span>
                }
            </div>
        </div>

        <div>
            <div class="card">
                <h2>Arquivo enviado pelo cliente</h2>
                @if (!string.IsNullOrWhiteSpace(Model.ArquivoClienteNome))
                {
                    <div class="file-card">
                        <span class="file-name">@Model.ArquivoClienteNome</span>
                        @if (Model.PodeBaixarArquivoCliente)
                        {
                            <a class="btn btn-primary" href="@Url.Action("BaixarArquivoCliente", "Atividade", new { id = Model.Id })">
                                Baixar arquivo do cliente
                            </a>
                        }
                    </div>
                }
                else
                {
                    <span class="empty">Nenhum arquivo enviado pelo cliente.</span>
                }
            </div>

            <div class="card" style="margin-top:18px;">
                <h2>Arquivo de resultado</h2>
                @if (!string.IsNullOrWhiteSpace(Model.ArquivoResultadoNome))
                {
                    <div class="file-card">
                        <span class="file-name">@Model.ArquivoResultadoNome</span>
                        @if (Model.PodeBaixarArquivoResultado)
                        {
                            <a class="btn btn-primary" href="@Url.Action("BaixarArquivoResultado", "Atividade", new { id = Model.Id })">
                                Baixar resultado
                            </a>
                        }
                    </div>
                }
                else
                {
                    <span class="empty">Nenhum arquivo de resultado enviado.</span>
                }
            </div>

            <div class="card" style="margin-top:18px;">
                <h2>A&ccedil;&otilde;es</h2>
                <div class="actions">
                    <a class="btn btn-secondary" href="@Url.Action(voltarAction, voltarController)">
                        Voltar
                    </a>

                    @if (Model.PodeEditarResultado)
                    {
                        <a class="btn btn-primary" href="@Url.Action("EditarResultado", "Atividade", new { id = Model.Id })">
                            Editar resultado
                        </a>
                    }

                    @if (Model.PodeFinalizar)
                    {
                        <a class="btn btn-primary" href="@Url.Action("Finalizar", "Atividade", new { id = Model.Id })">
                            Finalizar
                        </a>
                    }

                    @if (Model.PodeConfirmarLeitura)
                    {
                        <a class="btn btn-primary" href="@Url.Action("ConfirmarLeitura", "Atividade", new { id = Model.Id })">
                            Confirmar leitura
                        </a>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="card" style="margin-top:18px;">
        <h2>Hist&oacute;rico da atividade</h2>
        @if (Model.Historicos != null && Model.Historicos.Any())
        {
            <div class="history-list">
                @foreach (var item in Model.Historicos)
                {
                    <div class="history-item">
                        <div class="history-date">@item.DataHora.ToString("dd/MM/yyyy HH:mm")</div>
                        <div class="history-content">
                            <strong>@item.Acao</strong>
                            <span>@item.NomeUsuario (@item.TipoUsuario)</span>
                            <p>@item.Descricao</p>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <span class="empty">Nenhum hist&oacute;rico registrado para esta atividade.</span>
        }
    </div>
</div>
