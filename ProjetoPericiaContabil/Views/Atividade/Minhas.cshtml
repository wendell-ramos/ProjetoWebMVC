@model List<ProjetoPericiaContabil.Models.Atividade>

@{
    Layout = null;
}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">

<style>
    body {
        margin: 0;
        font-family: 'DM Sans', sans-serif;
        min-height: 100vh;
        background: linear-gradient(135deg, #1a2332, #243044, #0f172a);
        color: #fff;
    }

    .btn-logout {
        padding: 8px 14px;
        background: rgba(255,255,255,0.1);
        color: #fff;
        border-radius: 6px;
        text-decoration: none;
        font-size: 13px;
        transition: 0.2s;
        white-space: nowrap;
    }

        .btn-logout:hover {
            background: rgba(255,255,255,0.2);
        }

    .bg-circle {
        position: absolute;
        border-radius: 50%;
        filter: blur(120px);
        opacity: 0.3;
    }

    .circle1 {
        width: 300px;
        height: 300px;
        background: #c9a84c;
        top: 10%;
        left: 10%;
    }

    .circle2 {
        width: 400px;
        height: 400px;
        background: #3b82f6;
        bottom: 10%;
        right: 10%;
    }

    .container {
        padding: 40px;
        position: relative;
        z-index: 1;
    }

    .header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 20px;
        margin-bottom: 25px;
        flex-wrap: wrap;
    }

        .header h2 {
            font-family: 'Playfair Display', serif;
            font-size: 28px;
            margin: 0;
        }

    .header-buttons {
        display: flex;
        gap: 10px;
        align-items: center;
        flex-wrap: wrap;
        justify-content: flex-end;
    }

    .btn-top {
        padding: 8px 14px;
        background: linear-gradient(135deg, #c9a84c, #e0c36c);
        color: #1a2332;
        border-radius: 6px;
        text-decoration: none;
        font-size: 13px;
        font-weight: bold;
        transition: 0.2s;
        white-space: nowrap;
    }

        .btn-top:hover {
            box-shadow: 0 5px 15px rgba(201,168,76,0.4);
        }

    .btn {
        display: inline-block;
        padding: 6px 12px;
        background: linear-gradient(135deg, #c9a84c, #e0c36c);
        color: #1a2332;
        border-radius: 5px;
        text-decoration: none;
        font-size: 12px;
        font-weight: bold;
        transition: 0.2s;
        white-space: nowrap;
    }

        .btn:hover {
            box-shadow: 0 5px 15px rgba(201,168,76,0.4);
        }

    .card {
        background: rgba(255,255,255,0.05);
        backdrop-filter: blur(20px);
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 10px;
        overflow: hidden;
        box-shadow: 0 10px 40px rgba(0,0,0,0.4);
    }

    table {
        width: 100%;
        border-collapse: collapse;
    }

    th {
        padding: 14px;
        text-align: left;
        font-size: 13px;
        color: #c9a84c;
        border-bottom: 1px solid rgba(255,255,255,0.1);
    }

    td {
        padding: 14px;
        font-size: 14px;
        border-bottom: 1px solid rgba(255,255,255,0.05);
        vertical-align: top;
    }

    tr:hover {
        background: rgba(255,255,255,0.05);
    }

    .badge {
        padding: 4px 8px;
        border-radius: 4px;
        font-size: 12px;
        background: rgba(255,255,255,0.1);
    }

        .badge.analise {
            color: #60a5fa;
        }

        .badge.elab {
            color: #facc15;
        }

        .badge.done {
            color: #22c55e;
        }

    .resultado {
        color: #ddd;
        font-size: 13px;
        line-height: 1.5;
    }

        .resultado.empty {
            color: #888;
            font-style: italic;
        }

    .resultado-linha {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 20px;
        width: 100%;
    }

    .resultado-status {
        display: flex;
        justify-content: flex-end;
        align-items: center;
        min-width: 220px;
    }

    .visualizado {
        color: #22c55e;
        font-size: 12px;
        font-weight: bold;
        background: rgba(34,197,94,0.1);
        padding: 4px 10px;
        border-radius: 4px;
        display: inline-block;
        white-space: nowrap;
    }

    .arquivo-link {
        display: inline-block;
        color: #c9a84c;
        font-size: 12px;
        font-weight: bold;
        text-decoration: none;
        margin-bottom: 6px;
    }

        .arquivo-link:hover {
            text-decoration: underline;
        }

    .arquivo-vazio {
        color: #888;
        font-size: 12px;
        font-style: italic;
    }
</style>

<!-- Fundo -->
<div class="bg-circle circle1"></div>
<div class="bg-circle circle2"></div>

<div class="container">
    <div class="header">
        <h2>Minhas Atividades</h2>

        <div class="header-buttons">
            <a class="btn-top" href="@Url.Action("Create", "Atividade")">
                + Nova Atividade
            </a>

            <a class="btn-logout" href="@Url.Action("Logout", "Usuario")">
                Sair
            </a>
        </div>
    </div>

    <div class="card">
        <table>
            <tr>
                <th>Título</th>
                <th>Status</th>
                <th>Arquivos</th>
                <th>Resultado</th>
                <th>A&ccedil;&atilde;o</th>
            </tr>

            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Titulo</td>

                    <td>
                        @if (item.Status == "EmAnalise")
                        {
                            <span class="badge analise">Em análise</span>
                        }
                        else if (item.Status == "EmElaboracao")
                        {
                            <span class="badge elab">Em elaboração</span>
                        }
                        else if (item.Status == "Concluida")
                        {
                            <span class="badge done">Concluída</span>
                        }
                        else
                        {
                            <span class="badge">@item.Status</span>
                        }
                    </td>

                    <td>
                        @if (!string.IsNullOrEmpty(item.ArquivoClienteCaminho))
                        {
                            <a class="arquivo-link" href="@Url.Action("BaixarArquivoCliente", "Atividade", new { id = item.Id })">
                                Arquivo enviado
                            </a>
                            <br />
                        }

                        @if (!string.IsNullOrEmpty(item.ArquivoResultadoCaminho))
                        {
                            <a class="arquivo-link" href="@Url.Action("BaixarArquivoResultado", "Atividade", new { id = item.Id })">
                                Arquivo do resultado
                            </a>
                        }
                        else if (string.IsNullOrEmpty(item.ArquivoClienteCaminho))
                        {
                            <span class="arquivo-vazio">Sem arquivos</span>
                        }
                    </td>

                    <td>
                        @if (!string.IsNullOrEmpty(item.Resultado))
                        {
                            <div class="resultado-linha">
                                <span class="resultado">@item.Resultado</span>

                                <span class="resultado-status">
                                    @if (item.Status == "Concluida" && item.ClienteVisualizou == false)
                                    {
                                        <a class="btn" href="@Url.Action("ConfirmarLeitura", "Atividade", new { id = item.Id })">
                                            Marcar como visualizado
                                        </a>
                                    }
                                    else if (item.Status == "Concluida" && item.ClienteVisualizou == true)
                                    {
                                        <span class="visualizado">Visualizado</span>
                                    }
                                </span>
                            </div>
                        }
                        else
                        {
                            <span class="resultado empty">Aguardando conclusão</span>
                        }
                    </td>

                    <td>
                        <a class="btn" href="@Url.Action("Details", "Atividade", new { id = item.Id })">
                            Detalhes
                        </a>
                    </td>
                </tr>
            }
        </table>
    </div>
</div>
