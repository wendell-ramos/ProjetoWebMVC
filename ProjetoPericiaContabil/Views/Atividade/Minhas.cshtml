@model List<ProjetoPericiaContabil.Models.Atividade>

@{
    ViewBag.Title = "Minhas Atividades";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Minhas Atividades</h1>
        <p class="page-subtitle">Acompanhe solicita&ccedil;&otilde;es, arquivos enviados e resultados disponibilizados pela equipe pericial.</p>
    </div>
    <div class="page-actions">
        <a class="btn btn-primary" href="@Url.Action("Create", "Atividade")">
            <i class="bi bi-plus-circle"></i> Nova Atividade
        </a>
    </div>
</div>

<section class="card table-card">
    <div class="table-responsive">
        <table class="table app-table">
            <thead>
                <tr>
                    <th>T&iacute;tulo</th>
                    <th>Status</th>
                    <th>Arquivos</th>
                    <th>Resultado</th>
                    <th>A&ccedil;&atilde;o</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    var statusClass = item.Status == "EmAnalise" ? "status-analise" : item.Status == "EmElaboracao" ? "status-elaboracao" : item.Status == "Concluida" ? "status-concluida" : "status-default";
                    var statusText = item.Status == "EmAnalise" ? "Em an&aacute;lise" : item.Status == "EmElaboracao" ? "Em elabora&ccedil;&atilde;o" : item.Status == "Concluida" ? "Conclu&iacute;da" : item.Status;

                    <tr>
                        <td><strong>@item.Titulo</strong></td>
                        <td><span class="status-badge @statusClass">@Html.Raw(statusText)</span></td>
                        <td>
                            @if (!string.IsNullOrEmpty(item.ArquivoClienteCaminho))
                            {
                                <a class="arquivo-link d-block" href="@Url.Action("BaixarArquivoCliente", "Atividade", new { id = item.Id })">
                                    <i class="bi bi-paperclip"></i> Arquivo enviado
                                </a>
                            }
                            @if (!string.IsNullOrEmpty(item.ArquivoResultadoCaminho))
                            {
                                <a class="arquivo-link d-block" href="@Url.Action("BaixarArquivoResultado", "Atividade", new { id = item.Id })">
                                    <i class="bi bi-file-earmark-check"></i> Arquivo do resultado
                                </a>
                            }
                            else if (string.IsNullOrEmpty(item.ArquivoClienteCaminho))
                            {
                                <span class="arquivo-vazio">Sem arquivos</span>
                            }
                        </td>
                        <td>
                            @if (!string.IsNullOrEmpty(item.Resultado))
                            {
                                <div class="resultado">@item.Resultado</div>
                                if (item.Status == "Concluida" && item.ClienteVisualizou == false)
                                {
                                    <a class="btn btn-primary btn-sm mt-2" href="@Url.Action("ConfirmarLeitura", "Atividade", new { id = item.Id })">
                                        <i class="bi bi-check2"></i> Marcar como visualizado
                                    </a>
                                }
                                else if (item.Status == "Concluida" && item.ClienteVisualizou == true)
                                {
                                    <span class="status-badge status-success mt-2">Visualizado</span>
                                }
                            }
                            else
                            {
                                <span class="empty">Aguardando conclus&atilde;o</span>
                            }
                        </td>
                        <td>
                            <a class="btn btn-secondary btn-sm" href="@Url.Action("Details", "Atividade", new { id = item.Id })">
                                <i class="bi bi-eye"></i> Detalhes
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</section>
