@model List<ProjetoPericiaContabil.Models.Atividade>

@{
    Layout = null;
}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">

<style>
    body {
        margin: 0;
        font-family: 'DM Sans', sans-serif;
        min-height: 100vh;
        background: linear-gradient(135deg, #1a2332, #243044, #0f172a);
        color: #fff;
    }

    .bg-circle {
        position: absolute;
        border-radius: 50%;
        filter: blur(120px);
        opacity: 0.3;
    }

    .circle1 {
        width: 300px;
        height: 300px;
        background: #c9a84c;
        top: 10%;
        left: 10%;
    }

    .circle2 {
        width: 400px;
        height: 400px;
        background: #3b82f6;
        bottom: 10%;
        right: 10%;
    }

    .container {
        padding: 40px;
        position: relative;
        z-index: 1;
    }

    .header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 25px;
    }

        .header h2 {
            font-family: 'Playfair Display', serif;
            font-size: 28px;
            margin: 0;
        }

    .header-buttons {
        display: flex;
        gap: 10px;
        align-items: center;
    }

    .btn-top {
        padding: 8px 14px;
        background: rgba(255,255,255,0.1);
        border-radius: 6px;
        color: #fff;
        text-decoration: none;
        font-size: 13px;
        transition: 0.2s;
    }

        .btn-top:hover {
            background: rgba(255,255,255,0.2);
        }

    .card {
        background: rgba(255,255,255,0.05);
        backdrop-filter: blur(20px);
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 10px;
        overflow: hidden;
        box-shadow: 0 10px 40px rgba(0,0,0,0.4);
    }

    table {
        width: 100%;
        border-collapse: collapse;
    }

    th {
        padding: 14px;
        text-align: left;
        font-size: 13px;
        color: #c9a84c;
        border-bottom: 1px solid rgba(255,255,255,0.1);
    }

    td {
        padding: 14px;
        font-size: 14px;
        border-bottom: 1px solid rgba(255,255,255,0.05);
        vertical-align: top;
    }

    tr:hover {
        background: rgba(255,255,255,0.05);
    }

    .descricao {
        color: #ddd;
        font-size: 13px;
        line-height: 1.5;
    }

    .resultado {
        color: #ddd;
        font-size: 13px;
        line-height: 1.5;
    }

    .cliente-check {
        color: #22c55e;
        font-size: 12px;
        font-weight: bold;
    }

    .arquivo-link {
        display: inline-block;
        color: #c9a84c;
        font-size: 12px;
        font-weight: bold;
        text-decoration: none;
        margin-bottom: 6px;
    }

        .arquivo-link:hover {
            text-decoration: underline;
        }

    .arquivo-vazio {
        color: #888;
        font-size: 12px;
        font-style: italic;
    }
</style>

<div class="bg-circle circle1"></div>
<div class="bg-circle circle2"></div>

<div class="container">
    <div class="header">
        <h2>Atividades Arquivadas</h2>

        <div class="header-buttons">
            <a class="btn-top" href="@Url.Action("MinhasFuncionario", "Atividade")">
                Voltar
            </a>
        </div>
    </div>

    <div class="card">
        <table>
            <tr>
                <th>Título</th>
                <th>Descrição</th>
                <th>Resultado</th>
                <th>Arquivos</th>
                <th>Status</th>
            </tr>

            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Titulo</td>
                    <td><div class="descricao">@item.Descricao</div></td>
                    <td><div class="resultado">@item.Resultado</div></td>
                    <td>
                        @if (!string.IsNullOrEmpty(item.ArquivoClienteCaminho))
                        {
                            <a class="arquivo-link" href="@Url.Action("DownloadArquivo", "Atividade", new { id = item.Id, tipo = "cliente" })">
                                Arquivo do cliente
                            </a>
                            <br />
                        }

                        @if (!string.IsNullOrEmpty(item.ArquivoResultadoCaminho))
                        {
                            <a class="arquivo-link" href="@Url.Action("DownloadArquivo", "Atividade", new { id = item.Id, tipo = "resultado" })">
                                Arquivo do resultado
                            </a>
                        }
                        else if (string.IsNullOrEmpty(item.ArquivoClienteCaminho))
                        {
                            <span class="arquivo-vazio">Sem arquivos</span>
                        }
                    </td>
                    <td><span class="cliente-check">Visualizada pelo cliente</span></td>
                </tr>
            }
        </table>
    </div>
</div>
