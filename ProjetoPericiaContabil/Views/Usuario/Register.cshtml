@model ProjetoPericiaContabil.Models.Usuario

@{
    ViewBag.Title = "Cadastro";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="auth-card">
    <div class="auth-brand">
        <span class="brand-mark"><i class="bi bi-bank2"></i></span>
        <h1>Criar Conta</h1>
        <p>Cadastre-se para solicitar e acompanhar suas atividades.</p>
    </div>

    @if (ViewBag.Erro != null)
    {
        <div class="alert alert-danger">@ViewBag.Erro</div>
    }

    @Html.ValidationSummary(false, "", new { @class = "validation-summary-errors" })

    @using (Html.BeginForm("Register", "Usuario", FormMethod.Post, new { @class = "d-grid gap-3" }))
    {
        <div>
            <label class="form-label">Nome completo</label>
            @Html.TextBoxFor(model => model.Nome, new { @class = "form-control", placeholder = "Seu nome completo", required = "required" })
            @Html.ValidationMessageFor(model => model.Nome)
        </div>

        <div>
            <label class="form-label">E-mail</label>
            @Html.TextBoxFor(model => model.Email, new { @class = "form-control", placeholder = "seuemail@exemplo.com", type = "email", required = "required" })
            @Html.ValidationMessageFor(model => model.Email)
        </div>

        <div>
            <label class="form-label">Senha</label>
            @Html.PasswordFor(model => model.Senha, new { @class = "form-control", placeholder = "Crie uma senha segura", required = "required" })
            @Html.ValidationMessageFor(model => model.Senha)
        </div>

        <button type="submit" class="btn btn-primary w-100">
            <i class="bi bi-person-plus"></i> Cadastrar
        </button>
    }

    <div class="auth-link">
        J&aacute; tem conta?
        <a href="@Url.Action("Login", "Usuario")">Entrar</a>
    </div>
</section>
