@{
    ViewBag.Title = "Login";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="auth-card">
    <div class="auth-brand">
        <span class="brand-mark"><i class="bi bi-bank2"></i></span>
        <h1>Per&iacute;cia Cont&aacute;bil</h1>
        <p>Acesse o ambiente seguro de atividades periciais.</p>
    </div>

    @if (ViewBag.Erro != null)
    {
        <div class="alert alert-danger">@ViewBag.Erro</div>
    }

    @if (TempData["Sucesso"] != null)
    {
        <div class="alert alert-success">@TempData["Sucesso"]</div>
    }

    <form method="post" class="d-grid gap-3">
        <div>
            <label class="form-label">E-mail</label>
            <input class="form-control" type="email" name="email" placeholder="seuemail@exemplo.com" required />
        </div>

        <div>
            <label class="form-label">Senha</label>
            <input class="form-control" type="password" name="senha" placeholder="Digite sua senha" required />
        </div>

        <button type="submit" class="btn btn-primary w-100">
            <i class="bi bi-box-arrow-in-right"></i> Entrar
        </button>
    </form>

    <div class="auth-link">
        N&atilde;o tem conta?
        <a href="@Url.Action("Register", "Usuario")">Cadastrar</a>
    </div>
</section>
