@{
    Layout = null;
}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">

<style>
    body {
        margin: 0;
        font-family: 'DM Sans', sans-serif;
        height: 100vh;
        overflow: hidden;
        background: linear-gradient(135deg, #1a2332, #243044, #0f172a);
    }

    .bg-circle {
        position: absolute;
        border-radius: 50%;
        filter: blur(120px);
        opacity: 0.3;
    }

    .circle1 {
        width: 300px;
        height: 300px;
        background: #c9a84c;
        top: 10%;
        left: 10%;
    }

    .circle2 {
        width: 400px;
        height: 400px;
        background: #3b82f6;
        bottom: 10%;
        right: 10%;
    }

    .login-page {
        height: 100vh;
        display: flex;
        justify-content: center;
        align-items: center;
        position: relative;
        z-index: 1;
    }

    .login-card {
        background: rgba(255, 255, 255, 0.05);
        backdrop-filter: blur(20px);
        border: 1px solid rgba(255,255,255,0.1);
        width: 100%;
        max-width: 420px;
        box-shadow: 0 10px 40px rgba(0,0,0,0.4);
        border-radius: 10px;
        overflow: hidden;
        animation: fadeUp 0.5s ease;
    }

    @@keyframes fadeUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .login-header {
        padding: 2rem;
        text-align: center;
    }

        .login-header h2 {
            font-family: 'Playfair Display', serif;
            color: #fff;
            margin: 0;
            font-size: 28px;
        }

        .login-header p {
            color: #ccc;
            font-size: 13px;
            margin-top: 6px;
        }

    .login-body {
        padding: 2rem;
    }

        .login-body input {
            width: 100%;
            height: 45px;
            margin-bottom: 1rem;
            padding: 0 12px;
            border-radius: 6px;
            border: 1px solid rgba(255,255,255,0.2);
            background: rgba(255,255,255,0.1);
            color: #fff;
            outline: none;
            transition: 0.2s;
        }

            .login-body input::placeholder {
                color: #ccc;
            }

            .login-body input:focus {
                border-color: #c9a84c;
                background: rgba(255,255,255,0.15);
            }

        .login-body button {
            width: 100%;
            height: 45px;
            background: linear-gradient(135deg, #c9a84c, #e0c36c);
            color: #1a2332;
            border: none;
            border-radius: 6px;
            font-weight: bold;
            letter-spacing: 1px;
            cursor: pointer;
            margin-top: 10px;
            transition: 0.2s;
        }

            .login-body button:hover {
                transform: translateY(-2px);
                box-shadow: 0 5px 20px rgba(201,168,76,0.4);
            }

    .error {
        color: #ff6b6b;
        font-size: 13px;
        margin-top: 10px;
        text-align: center;
    }

    .register-link {
        text-align: center;
        margin-top: 15px;
        font-size: 13px;
        color: #ccc;
    }

        .register-link a {
            color: #c9a84c;
            text-decoration: none;
            font-weight: 500;
        }

            .register-link a:hover {
                text-decoration: underline;
            }
</style>

<!-- Fundo -->
<div class="bg-circle circle1"></div>
<div class="bg-circle circle2"></div>

<div class="login-page">
    <div class="login-card">

        <div class="login-header">
            <h2>Perícia Contábil</h2>
            <p>Entre na sua conta</p>
        </div>

        <div class="login-body">
            <form method="post">
                <input type="email" name="email" placeholder="Email" required />
                <input type="password" name="senha" placeholder="Senha" required />

                <button type="submit">Entrar</button>
            </form>

            @if (ViewBag.Erro != null)
            {
                <div class="error">@ViewBag.Erro</div>
            }

            <div class="register-link">
                Não tem conta?
                <a href="/Usuario/Register">Cadastrar</a>
            </div>
        </div>

    </div>
</div>