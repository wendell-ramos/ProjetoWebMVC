@model List<ProjetoPericiaContabil.Models.Usuario>
@using ProjetoPericiaContabil.Models
@using System.Collections.Generic

@{
    ViewBag.Title = "Painel do Admin";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var cargosPermitidos = ViewBag.CargosPermitidos as string[] ?? new[] { "C\u00edvel", "Trabalhista", "Tribut\u00e1rio", "Previdenci\u00e1rio" };
    var atividadesPorStatus = ViewBag.AtividadesPorStatus as Dictionary<string, int> ?? new Dictionary<string, int>();
    var atividadesPorTipo = ViewBag.AtividadesPorTipo as Dictionary<string, int> ?? new Dictionary<string, int>();
    var rankingFuncionarios = ViewBag.RankingFuncionarios as List<Tuple<string, string, int>> ?? new List<Tuple<string, string, int>>();
    var ultimasAtividades = ViewBag.UltimasAtividades as List<Atividade> ?? new List<Atividade>();
    var atividadesAguardandoCliente = ViewBag.AtividadesAguardandoCliente as List<Atividade> ?? new List<Atividade>();
    var atividadesSemFuncionario = ViewBag.AtividadesSemFuncionario as List<Atividade> ?? new List<Atividade>();
    var maxStatus = atividadesPorStatus.Count > 0 ? atividadesPorStatus.Values.Max() : 1;
    var maxTipo = atividadesPorTipo.Count > 0 ? atividadesPorTipo.Values.Max() : 1;
}

<div class="page-header">
    <div>
        <h1 class="page-title">Painel do Admin</h1>
        <p class="page-subtitle">Vis&atilde;o gerencial de usu&aacute;rios, permiss&otilde;es, atividades, arquivos e produtividade da equipe.</p>
    </div>
    <div class="page-actions">
        <a href="@Url.Action("Historico", "Admin")" class="btn btn-primary">
            <i class="bi bi-clock-history"></i> Ver Hist&oacute;rico do Sistema
        </a>
    </div>
</div>

@if (TempData["Erro"] != null)
{
    <div class="alert alert-danger">@TempData["Erro"]</div>
}

@if (TempData["Sucesso"] != null)
{
    <div class="alert alert-success">@TempData["Sucesso"]</div>
}

<section class="metric-grid">
    <div class="metric-card">
        <span class="metric-icon"><i class="bi bi-people"></i></span>
        <span class="metric-label">Total de usu&aacute;rios</span>
        <strong class="metric-value">@ViewBag.TotalUsuarios</strong>
    </div>
    <div class="metric-card">
        <span class="metric-icon"><i class="bi bi-person"></i></span>
        <span class="metric-label">Clientes</span>
        <strong class="metric-value">@ViewBag.TotalClientes</strong>
    </div>
    <div class="metric-card">
        <span class="metric-icon"><i class="bi bi-briefcase"></i></span>
        <span class="metric-label">Funcion&aacute;rios</span>
        <strong class="metric-value">@ViewBag.TotalFuncionarios</strong>
    </div>
    <div class="metric-card">
        <span class="metric-icon"><i class="bi bi-folder2-open"></i></span>
        <span class="metric-label">Atividades</span>
        <strong class="metric-value">@ViewBag.TotalAtividades</strong>
    </div>
    <div class="metric-card">
        <span class="metric-icon"><i class="bi bi-check2-circle"></i></span>
        <span class="metric-label">Conclu&iacute;das</span>
        <strong class="metric-value">@ViewBag.TotalConcluidas</strong>
    </div>
    <div class="metric-card">
        <span class="metric-icon"><i class="bi bi-eye"></i></span>
        <span class="metric-label">Aguardando cliente</span>
        <strong class="metric-value">@ViewBag.AguardandoClienteVisualizar</strong>
    </div>
    <div class="metric-card">
        <span class="metric-icon"><i class="bi bi-person-dash"></i></span>
        <span class="metric-label">Sem respons&aacute;vel</span>
        <strong class="metric-value">@ViewBag.SemFuncionarioResponsavel</strong>
    </div>
    <div class="metric-card">
        <span class="metric-icon"><i class="bi bi-paperclip"></i></span>
        <span class="metric-label">Arquivos anexados</span>
        <strong class="metric-value">@ViewBag.TotalArquivosAnexados</strong>
    </div>
</section>

<section class="panel-grid">
    <div class="panel">
        <h3>Gr&aacute;fico por status</h3>
        @if (atividadesPorStatus.Count > 0)
        {
            foreach (var item in atividadesPorStatus)
            {
                var largura = maxStatus == 0 ? 0 : (item.Value * 100 / maxStatus);
                <div class="bar-row">
                    <div class="bar-label">
                        <span>@item.Key</span>
                        <strong>@item.Value</strong>
                    </div>
                    <div class="bar-track">
                        <div class="bar-fill" style="width:@largura%"></div>
                    </div>
                </div>
            }
        }
        else
        {
            <span class="empty">Nenhuma atividade cadastrada.</span>
        }
    </div>

    <div class="panel">
        <h3>Gr&aacute;fico por tipo de c&aacute;lculo</h3>
        @if (atividadesPorTipo.Count > 0)
        {
            foreach (var item in atividadesPorTipo)
            {
                var largura = maxTipo == 0 ? 0 : (item.Value * 100 / maxTipo);
                <div class="bar-row">
                    <div class="bar-label">
                        <span>@item.Key</span>
                        <strong>@item.Value</strong>
                    </div>
                    <div class="bar-track">
                        <div class="bar-fill" style="width:@largura%"></div>
                    </div>
                </div>
            }
        }
        else
        {
            <span class="empty">Nenhuma atividade cadastrada.</span>
        }
    </div>

    <div class="panel">
        <h3>Ranking de funcion&aacute;rios</h3>
        <div class="activity-list">
            @if (rankingFuncionarios.Count > 0)
            {
                foreach (var item in rankingFuncionarios)
                {
                    <div class="activity-item">
                        <span class="activity-title">@item.Item1 <span class="text-muted-app">@item.Item2</span></span>
                        <span class="activity-meta">@item.Item3 atividades</span>
                    </div>
                }
            }
            else
            {
                <span class="empty">Nenhum funcion&aacute;rio com atividade.</span>
            }
        </div>
    </div>

    <div class="panel">
        <h3>&Uacute;ltimas atividades criadas</h3>
        <div class="activity-list">
            @if (ultimasAtividades.Count > 0)
            {
                foreach (var item in ultimasAtividades)
                {
                    <div class="activity-item">
                        <span class="activity-title">@item.Titulo</span>
                        <a class="activity-meta" href="@Url.Action("Details", "Atividade", new { id = item.Id })">Detalhes #@item.Id</a>
                    </div>
                }
            }
            else
            {
                <span class="empty">Nenhuma atividade cadastrada.</span>
            }
        </div>
    </div>

    <div class="panel">
        <h3>Atividades aguardando cliente visualizar</h3>
        <div class="activity-list">
            @if (atividadesAguardandoCliente.Count > 0)
            {
                foreach (var item in atividadesAguardandoCliente)
                {
                    <div class="activity-item">
                        <span class="activity-title">@item.Titulo</span>
                        <a class="activity-meta" href="@Url.Action("Details", "Atividade", new { id = item.Id })">Detalhes #@item.Id</a>
                    </div>
                }
            }
            else
            {
                <span class="empty">Nenhuma atividade aguardando visualiza&ccedil;&atilde;o.</span>
            }
        </div>
    </div>

    <div class="panel">
        <h3>Atividades sem funcion&aacute;rio respons&aacute;vel</h3>
        <div class="activity-list">
            @if (atividadesSemFuncionario.Count > 0)
            {
                foreach (var item in atividadesSemFuncionario)
                {
                    <div class="activity-item">
                        <span class="activity-title">@item.Titulo</span>
                        <a class="activity-meta" href="@Url.Action("Details", "Atividade", new { id = item.Id })">Detalhes #@item.Id</a>
                    </div>
                }
            }
            else
            {
                <span class="empty">Nenhuma atividade sem respons&aacute;vel.</span>
            }
        </div>
    </div>
</section>

<div class="page-header mt-4">
    <div>
        <h1 class="page-title">Usu&aacute;rios</h1>
        <p class="page-subtitle">Promova clientes para funcion&aacute;rios e defina o setor correto de atua&ccedil;&atilde;o.</p>
    </div>
</div>

<section class="card table-card">
    <div class="table-responsive">
        <table class="table app-table">
            <thead>
                <tr>
                    <th>Nome</th>
                    <th>Email</th>
                    <th>Tipo</th>
                    <th>Cargo/Setor</th>
                    <th>A&ccedil;&atilde;o</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td><strong>@item.Nome</strong></td>
                        <td>@item.Email</td>
                        <td><span class="status-badge status-default">@item.Tipo</span></td>
                        <td>
                            @if (!string.IsNullOrEmpty(item.Cargo))
                            {
                                <span class="text-muted-app">@item.Cargo</span>
                            }
                            else
                            {
                                <span class="empty">Sem cargo</span>
                            }
                        </td>
                        <td>
                            @if (item.Tipo == "Cliente")
                            {
                                using (Html.BeginForm("TornarFuncionario", "Usuario", new { id = item.Id }, FormMethod.Post, new { @class = "form-cargo" }))
                                {
                                    <select class="form-select" name="cargo" required>
                                        @foreach (var cargo in cargosPermitidos)
                                        {
                                            <option value="@cargo">@cargo</option>
                                        }
                                    </select>
                                    <button type="submit" class="btn btn-primary btn-sm">
                                        <i class="bi bi-person-check"></i> Tornar Funcion&aacute;rio
                                    </button>
                                }
                            }
                            else
                            {
                                <span class="empty">Nenhuma a&ccedil;&atilde;o dispon&iacute;vel</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</section>
