@{
    ViewBag.Title = "In&iacute;cio";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="hero-panel">
    <div>
        <span class="status-badge status-analise mb-3">Sistema de gest&atilde;o pericial</span>
        <h1 class="hero-title">Per&iacute;cia Cont&aacute;bil com controle, rastreabilidade e organiza&ccedil;&atilde;o.</h1>
        <p class="hero-copy">
            Ambiente profissional para cria&ccedil;&atilde;o de atividades, acompanhamento por setor,
            entrega de resultados, arquivos anexados e hist&oacute;rico administrativo.
        </p>
        <div class="actions mt-4">
            <a class="btn btn-primary" href="@Url.Action("Login", "Usuario")">
                <i class="bi bi-box-arrow-in-right"></i> Entrar no sistema
            </a>
        </div>
    </div>

    <div class="surface">
        <h2>Fluxo operacional</h2>
        <div class="feature-list">
            <div class="feature-item">
                <i class="bi bi-file-earmark-plus"></i>
                <div>
                    <strong>Cliente cria atividade</strong>
                    <div class="text-muted-app">Solicita an&aacute;lise e anexa documentos iniciais.</div>
                </div>
            </div>
            <div class="feature-item">
                <i class="bi bi-briefcase"></i>
                <div>
                    <strong>Funcion&aacute;rio assume pelo setor</strong>
                    <div class="text-muted-app">Atividades seguem o tipo de c&aacute;lculo definido.</div>
                </div>
            </div>
            <div class="feature-item">
                <i class="bi bi-check2-circle"></i>
                <div>
                    <strong>Resultado e hist&oacute;rico</strong>
                    <div class="text-muted-app">Entrega final, arquivos e logs ficam centralizados.</div>
                </div>
            </div>
        </div>
    </div>
</section>
